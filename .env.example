# JARVIS OS — Environment Variables
# Copy to .env.local and fill in your keys

# Required: Anthropic API key for JARVIS intelligence
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: ElevenLabs for premium Daniel voice
# VITE_ELEVENLABS_API_KEY=sk_your-elevenlabs-key

# Optional: Supabase for cloud persistence
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ-your-anon-key

# Optional: Sentry error monitoring (free at sentry.io)
# VITE_SENTRY_DSN=https://your-key@o123.ingest.sentry.io/456
